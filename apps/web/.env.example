# Required for production
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io   # from Upstash console or Vercel integration
# UPSTASH_REDIS_REST_TOKEN=<token>                           # from Upstash console or Vercel integration
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_CLIENT_ID=          # GitHub App OAuth Client ID (Iv1.xxx)
# GITHUB_CLIENT_SECRET=      # GitHub App OAuth Client Secret
# BYOK_ACTIVE_KEY_VERSION=   # Active master key version (e.g. "v1")
# BYOK_MASTER_KEYS=          # JSON keyring: {"v1":"<64-hex-char-key>"}
# NEXT_PUBLIC_SITE_URL=https://hivemoot.dev
